datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @unique
  password   String
  name       String?
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  forms       Form[]
  sharedForms FormCollaborator[]

  @@map("users")
}

enum QuestionType {
  TEXT
  TEXTAREA
  RADIO
  CHECKBOX
  PAGE_BREAK
}

model Form {
  id          String  @id @default(uuid())
  title       String
  description String?

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questions     FormQuestion[]
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  responses     Response[]
  collaborators FormCollaborator[]
}

model FormQuestion {
  id              String           @id @default(uuid())
  type            QuestionType
  title           String
  description     String?
  isRequired      Boolean          @default(false)
  order           Int
  formId          String
  form            Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  validationRules Json?
  options         QuestionOption[]
  answers         Answer[]
}

model QuestionOption {
  id         String       @id @default(uuid())
  text       String
  order      Int
  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Response {
  id             String   @id @default(uuid())
  formId         String
  respondentName String // Обов'язкове поле для імені респондента
  created_at     DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Answer {
  id         String @id @default(uuid())
  responseId String
  questionId String
  value      String // Значення відповіді (текст або масив ID опцій у вигляді JSON-рядка)

  response Response     @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model FormCollaborator {
  id      String   @id @default(uuid())
  formId  String // <-- ПРИБРАТИ @db.Uuid
  userId  String   @db.Uuid // <-- ЗАЛИШИТИ @db.Uuid
  addedAt DateTime @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
}
